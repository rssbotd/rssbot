#!/usr/bin/env python3
# This file is placed in the Public Domain.


"stress test"


import os
import queue
import shutil
import sys
import threading
import time


sys.path.insert(0, os.getcwd())


from rssbot.command import Commands
from rssbot.defines import Main
from rssbot.handler import Client, Event
from rssbot.loggers import Log
from rssbot.objects import Data, Methods
from rssbot.package import Mods
from rssbot.persist import Workdir
from rssbot.runtime import Runtime
from rssbot.threads import Thread
from rssbot.utility import Time, Utils


from rssbot import modules as MODS


try:
    import mods as MODS2
except ModuleNotFoundError:
    MODS2 = None


events = queue.Queue()


Main.debug = True
Main.ignore = ""
Main.level = "info"
Main.mods = ""
Main.name = Utils.pkgname(Commands)
Main.opts = Data()
Main.version = 8
Main.wdr = ".test"


class CLI(Client):

    def __init__(self):
        Client.__init__(self)
        self.register("command", Commands.command)

    def raw(self, text):
        if "v" in Main.opts:
            print(text)


class Clients:

    clients = []
    lock = threading.RLock()
    nrcpu = 1
    last = 0

    @staticmethod
    def add(client):
        Clients.clients.append(client)

    @staticmethod
    def init(nrcpu, cls):
        Clients.nrcpu = nrcpu
        for _x in range(Clients.nrcpu):
            clt = cls()
            clt.start()
            Clients.add(clt)

    @staticmethod
    def put(*args):
        with Clients.lock:
            if Clients.last >= Clients.nrcpu-1:
                Clients.last = 0
            clt = Clients.clients[Clients.last]
            clt.put(*args)
            Clients.last += 1


def consume():
    while True:
        try:
            event = events.get()
            event.wait()
            events.task_done()
        except (KeyboardInterrupt, EOFError):
            os._exit(0)


def payload(todo):
    for cmd, example in todo.items():
        if Main.cmd:
            if cmd not in Utils.spl(Main.cmd):
                continue
        for ex in example:
            evt = Event()
            evt.text = f"{cmd} {ex}"
            evt.kind = "command"
            Clients.put(evt)
            events.put(evt)


def main():
    if "p" not in Main.opts and os.path.exists(Main.wdr):
        shutil.rmtree(Main.wdr)
    Methods.parse(Main, " ".join(sys.argv[1:]))
    Workdir.setwd(Main.wdr)
    Log.level(Main.level)
    Mods.add("modules", MODS.__path__[0])
    if MODS2:
        Mods.add("mods", MODS2.__path__[0])
    Main.mods = Main.mods or Mods.list()
    Runtime.scanner(Main)
    if "v" in Main.opts:
        Runtime.banner()
    if "z" in Main.opts:
        Clients.init(os.cpu_count(), CLI)
    else:
        Clients.init(1, CLI)
    starttime = time.time()
    nrs = Main.index or 1
    for _x in range(nrs):
        payload(pre)
    for _x in range(nrs):
        payload(examples)
    for _x in range(nrs):
        payload(post)
    Thread.launch(consume)
    nrevents = events.qsize()
    try:
        events.join()
    except (KeyboardInterrupt, EOFError):
        pass
    endtime = time.time()
    lap = Time.elapsed(endtime-starttime)
    percall = (endtime-starttime)/nrevents
    nrs = events.qsize()
    Runtime.shutdown()
    if "v" in Main.opts:
        print(f"{Methods.fmt(Main, skip='otxt,txt')}")
        print(f"{nrs} events left.")
        print(f"total: {lap} nrs: {nrevents} call: %.6fs" % percall)


examples = {
    "atr": [""],
    "cmd": [""],
    "dis": [""],
    "dne": ["", "bla"],
    "dpl": ["hnrss title,url", ""],
    "eml": ["", "root@localhost"],
    "flt": ["", "0"],
    "fnd": ["", "log", "rss", "config", "todo"],
    "lou": [""],
    "man": ["", "rssbot genocideniet@gmail.com Nixt Niet"],
    "mbx": [""],
    "mod": [""],
    "mre": [""],
    "nme": ["", "hnrss hackernews"],
    "now": [""],
    "pth": [""],
    "pwd": ["", "bla mekker"],
    "req": [""],
    "res": ["", "hnrss"],
    "sil": [""],
    "slg": [""],
    "srv": [""],
    "syn": [""],
    "thr": [""],
    "tmr": ["", "22:00 test"],
    "upt": [""],
    "wsd": [""]
}

pre = {
    "cfg": ["", "nick=mekker"],
    "imp": [
        "",
        "testing/opml/feeds.opml",
    ],
    "log": ["", "log add"],
    "rss": ["", "http://hnrss.org/newest"],
    "tdo": ["", "test"]
}

post = {
    "dbg": [""],
    "dne": ["", "mekker"],
    "exp": [""],
    "rem": ["", "hnrss"]
}


if __name__ == "__main__":
    Runtime.wrap(main)
